# .easignore - EAS Build用（.gitignoreをベースに、ビルドに必要なファイルを含める）

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# NOTE: google-services.json はビルドに必要なため除外しない

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# temporary files
log.txt
nul
*.jpg

# screenshots (development only)
screenshots/

serviceAccountKey.json
